    "channel",
    F.when(F.col("StoreKey").isNull(), "Online").otherwise("In-Store")
).groupBy("channel", "Continent") \
 .agg(
    (F.sum("revenue_usd") / F.countDistinct("Order Number")).alias("AOV")
 )

display(kpi6)
